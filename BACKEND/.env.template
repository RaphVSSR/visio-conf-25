# Configuration Backend

# Base de données MongoDB (simplifiée sans authentification)
MONGO_URI=mongodb://localhost:27017/visio-conf

# Configuration serveur
PORT=3220
VERBOSE=false
VERBOSE_LVL=3 #1 to lvl 3
FRONTEND_URL=http://localhost:3000
API_BASE_PREFIX=/api
FLUSH_DB_ON_START=true

# URLs pour le stockage de fichiers
FILE_STORAGE_URL=http://localhost:3220/api/files
PROFILE_PICTURES_URL=http://localhost:3220/api/files/profile

# Chaîne de caractères — format zeit/ms (ex: "24h", "7d", "60m", "3600s")
SESSION_DURATION=24h

# Entier — en secondes, délai d'attente pour l'approbation multi-session
SESSION_APPROVAL_TIMEOUT_SECONDS=60

# Note:
# - Pour MongoDB local: utilisez mongodb://localhost:27017/visioconf
# - Pour MongoDB Atlas: utilisez mongodb+srv://username:password@cluster.mongodb.net/visioconf
# - CORS est configuré automatiquement pour localhost et adresses IP locales
