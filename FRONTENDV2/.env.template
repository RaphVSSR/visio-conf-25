# Configuration Frontend - Copiez ce fichier vers .env.local
# Le fichier .env.local sera ignoré par git pour la sécurité

# Verbosité (false par défaut, niveaux 1-3)
REACT_APP_VERBOSE=false
REACT_APP_VERBOSE_LVL=1

# Session
REACT_APP_SESSION_EXPIRY_WARNING_MS=1800000
REACT_APP_SESSION_STORAGE_KEY=visioconf_session

# URL de l'API Backend
REACT_APP_BACKEND_API_URL=http://localhost:3220

# URLs pour le stockage de fichiers
REACT_APP_BACKEND_FILE_STORAGE_URL=http://localhost:3220/api/files
REACT_APP_BACKEND_PROFILE_PICTURES_URL=http://localhost:3220/api/files/profile
